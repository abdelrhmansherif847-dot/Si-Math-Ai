    <div class="delete-confirm-input">
      <p>To confirm, type <strong>DELETE</strong> in the box below:</p>
      <input class="fi" type="text" id="delete-confirm" placeholder="Type DELETE to confirm" oninput="checkDelete()" style="border-color:var(--red-ring)">
    </div>
    <button class="btn-delete-confirm" id="delete-confirm-btn">Delete My Account Forever</button>
    <button class="btn-cancel-red" onclick="closeModal('delete-modal')">Cancel — Keep My Account</button>
  </div>
</div>

<!-- ════ TOAST ════ -->
<div class="toast" id="toast">
  <span style="font-size:16px">✅</span>
  <span id="toast-msg">Changes saved successfully</span>
</div>

<script>
/* ── sidebar active ── */
function scrollTo(id) {
  document.getElementById(id).scrollIntoView({behavior:'smooth'});
  document.querySelectorAll('.sb-link').forEach(el => el.classList.remove('active'));
  event.currentTarget.classList.add('active');
}

/* ── modal ── */
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
function handleOv(e, id) { if (e.target === e.currentTarget) closeModal(id); }

/* ── option pills ── */
function selectOpt(el, groupId) {
  document.querySelectorAll('#' + groupId + ' .opt-pill').forEach(p => p.classList.remove('selected'));
  el.classList.add('selected');
  toastSave();
}

/* ── toast ── */
let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  const m = document.getElementById('toast-msg');
  m.textContent = msg || 'Changes saved successfully';
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2800);
}
function toastSave() { showToast('Changes saved successfully'); }
function toastExport() { showToast('Export started — check your email shortly'); }

/* ── account save ── */
function saveAccount() {
  const name = document.getElementById('f-name').value.trim();
  if (name) {
    // update avatar initial
    document.getElementById('avatar-preview').textContent = name[0].toUpperCase();
  }
  showToast('Profile updated — changes reflected in Profile page');
}
function resetAccount() {
  document.getElementById('f-name').value = 'Abdelrhman';
  document.getElementById('f-email').value = 'abdelrhman@example.com';
}

/* ── password ── */
function checkPwd() {
  const a = document.getElementById('new-pwd').value;
  const b = document.getElementById('confirm-pwd').value;
  const el = document.getElementById('pwd-match');
  if (!b) { el.textContent = ''; return; }
  if (a === b) {
    el.style.color = 'var(--green)';
    el.textContent = '✓ Passwords match';
  } else {
    el.style.color = 'var(--red)';
    el.textContent = '✗ Passwords do not match';
  }
}
function savePwd() {
  const a = document.getElementById('new-pwd').value;
  const b = document.getElementById('confirm-pwd').value;
  if (a && a === b) {
    closeModal('pwd-modal');
    showToast('Password updated successfully');
  }
}

/* ── delete confirm ── */
function checkDelete() {
  const val = document.getElementById('delete-confirm').value;
  const btn = document.getElementById('delete-confirm-btn');
  btn.classList.toggle('armed', val === 'DELETE');
}

/* ── log out confirm ── */
function confirmLogout() {
  if (confirm('Log out from all devices? You will need to sign in again.')) {
    showToast('Logged out from all other devices');
  }
}

/* ── scroll spy ── */
const sections = ['s-account','s-security','s-notif','s-study','s-appear','s-privacy','s-support','s-danger'];
const links = document.querySelectorAll('.sb-link');

const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const idx = sections.indexOf(entry.target.id);
      if (idx >= 0) {
        links.forEach(l => l.classList.remove('active'));
        if (links[idx]) links[idx].classList.add('active');
      }
    }
  });
}, { rootMargin: '-30% 0px -60% 0px' });

sections.forEach(id => {
  const el = document.getElementById(id);
  if (el) observer.observe(el);
});
</script>
</body>
</html>
